# ===================================================
# アフィリエイトチーム 環境変数テンプレート
# このファイルをコピーして .env を作成し、実際の値を入力してください
# .env は .gitignore でバージョン管理から除外されています
#
# Codespaces利用時はGitHub Secretsから自動注入されるため、
# .envファイルを作成する必要はありません
# ===================================================

# ── Google Gemini API（無料枠：Google AI Studio で取得）──
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── YouTube Data API v3（無料枠：Google Cloud Console で取得）──
# https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Threads API（Meta Developer Portal で取得・要審査）──
# https://developers.facebook.com/docs/threads
THREADS_ACCESS_TOKEN=your_threads_access_token_here
THREADS_USER_ID=your_threads_user_id_here

# ── GitHub API（Personal Access Token）──
# https://github.com/settings/tokens
# 必要なスコープ: repo (Issues の読み書き)
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO=your_github_username/your_repo_name

# ── Discord Webhook URL（承認通知用・推奨・完全無料）──
# 設定方法: Discordサーバー → チャンネル設定 → 連携サービス → ウェブフック → 新しいウェブフック
# DISCORD_WEBHOOK_URL と MAKE_WEBHOOK_URL は両方設定しなくてもOK。片方だけでも動く。
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# ── Make Webhook URL（承認通知用・LINE等に転送したい場合）──
# https://www.make.com/
MAKE_WEBHOOK_URL=https://hook.eu1.make.com/your_webhook_id_here

# ===================================================
# アフィリエイトチーム専用の追加設定
# ===================================================

# ── 楽天アフィリエイト ──
# アフィリエイト登録: https://affiliate.rakuten.co.jp/
# 新APIアプリ登録（applicationId+accessKey発行）: https://webservice.rakuten.co.jp/
# 2026/02 以降の新ポータルでは applicationId と accessKey の両方が必須
RAKUTEN_APP_ID=your_rakuten_app_id_here
RAKUTEN_ACCESS_KEY=your_rakuten_access_key_here
RAKUTEN_AFFILIATE_ID=your_rakuten_affiliate_id_here

# ── Amazon アソシエイト / PA-API ──
# https://affiliate.amazon.co.jp/
# PA-APIは過去30日に3件以上の売上が必要
AMAZON_ACCESS_KEY=your_amazon_access_key_here
AMAZON_SECRET_KEY=your_amazon_secret_key_here
AMAZON_ASSOCIATE_TAG=your_associate_tag-22
AMAZON_COUNTRY=JP

# ── Google Sheets（収益記録用・既存ワークフローと共通）──
SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_CREDENTIALS_PATH=credentials/sheets_service_account.json
