# Hogwarts environment variables
# Copy this file to .env and fill in real values for local development.
# GitHub Actions uses repository secrets with the same names.

# Meta Threads API access token
THREADS_API_TOKEN=your-threads-api-token-here

# GitHub personal access token (for API / automation)
# Local dev: use GITHUB_TOKEN in .env
# GitHub Actions: stored as GH_TOKEN (GITHUB_* prefix is reserved by GitHub)
GITHUB_TOKEN=your-github-token-here
GH_TOKEN=your-github-token-here
